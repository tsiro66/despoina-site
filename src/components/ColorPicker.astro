---
// Floating color picker for demo — lets client change the forest color in real-time
---

<div id="color-picker-widget" class="fixed bottom-6 right-6 z-[9999] flex items-end gap-3">
  <!-- Color picker panel (hidden by default) -->
  <div id="color-panel" class="hidden bg-white rounded-2xl shadow-2xl p-5 mb-1 border border-zinc-200 w-64 animate-fade-in">
    <p class="text-sm font-bold text-zinc-800 mb-3 font-syne">Αλλαγή χρώματος</p>

    <!-- Preset swatches -->
    <div class="grid grid-cols-5 gap-2 mb-4">
      <button data-color="#0B2F1F" class="color-swatch w-9 h-9 rounded-full border-2 border-transparent hover:scale-110 transition-transform" style="background:#0B2F1F" aria-label="Forest (default)"></button>
      <button data-color="#000000" class="color-swatch w-9 h-9 rounded-full border-2 border-transparent hover:scale-110 transition-transform" style="background:#000000" aria-label="Black"></button>
      <button data-color="#001F3F" class="color-swatch w-9 h-9 rounded-full border-2 border-transparent hover:scale-110 transition-transform" style="background:#001F3F" aria-label="Navy Blue"></button>
      <button data-color="#333D1E" class="color-swatch w-9 h-9 rounded-full border-2 border-transparent hover:scale-110 transition-transform" style="background:#333D1E" aria-label="Army Green"></button>
      <button data-color="#1C1C1C" class="color-swatch w-9 h-9 rounded-full border-2 border-transparent hover:scale-110 transition-transform" style="background:#1C1C1C" aria-label="Anthracite"></button>
    </div>

    <!-- Custom color input -->
    <div class="flex items-center gap-2">
      <label for="custom-color" class="text-xs text-zinc-500 font-google-sans whitespace-nowrap">Custom:</label>
      <input type="color" id="custom-color" value="#0B2F1F" class="w-10 h-8 rounded cursor-pointer border-0 p-0 bg-transparent" />
      <div class="flex items-center bg-zinc-100 rounded px-2 py-1">
        <span class="text-xs text-zinc-400 font-google-sans" aria-hidden="true">#</span>
        <input type="text" id="hex-input" value="0B2F1F" maxlength="6" aria-label="Hex χρώμα" class="w-16 text-xs text-zinc-700 font-google-sans tracking-wide bg-transparent border-0 outline-none p-0 pl-0.5" placeholder="0B2F1F" />
      </div>
    </div>

    <!-- Reset button -->
    <button id="reset-color" class="mt-3 text-xs text-zinc-400 hover:text-zinc-600 transition-colors font-google-sans underline underline-offset-2">
      Επαναφορά αρχικού
    </button>
  </div>

  <!-- Toggle button -->
  <button id="color-toggle" class="w-14 h-14 rounded-full bg-forest text-white shadow-xl hover:shadow-2xl hover:scale-105 transition-all duration-200 flex items-center justify-center" aria-label="Αλλαγή χρώματος" aria-expanded="false" aria-controls="color-panel">
    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="13.5" cy="6.5" r="2.5"/>
      <circle cx="17.5" cy="10.5" r="2.5"/>
      <circle cx="8.5" cy="7.5" r="2.5"/>
      <circle cx="6.5" cy="12.5" r="2.5"/>
      <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"/>
    </svg>
  </button>
</div>

<style>
  @keyframes fade-in {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fade-in 0.2s ease-out;
  }
  .color-swatch.active {
    border-color: white;
    box-shadow: 0 0 0 2px currentColor, 0 0 0 4px white;
  }
</style>

<script>
  function initColorPicker() {
    const DEFAULT_COLOR = '#0B2F1F';
    const toggle = document.getElementById('color-toggle')!;
    const panel = document.getElementById('color-panel')!;
    const customInput = document.getElementById('custom-color') as HTMLInputElement;
    const hexInput = document.getElementById('hex-input') as HTMLInputElement;
    const resetBtn = document.getElementById('reset-color')!;
    const swatches = document.querySelectorAll('.color-swatch');

    // Restore saved color
    const saved = localStorage.getItem('demo-forest-color');
    if (saved) applyColor(saved);

    function openPanel() {
      panel.classList.remove('hidden');
      toggle.setAttribute('aria-expanded', 'true');
    }

    function closePanel() {
      panel.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
    }

    // Toggle panel
    toggle.addEventListener('click', () => {
      panel.classList.contains('hidden') ? openPanel() : closePanel();
    });

    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !panel.classList.contains('hidden')) {
        closePanel();
        toggle.focus();
      }
    });

    // Close on outside click
    document.addEventListener('click', (e) => {
      const widget = document.getElementById('color-picker-widget')!;
      if (!widget.contains(e.target as Node)) {
        closePanel();
      }
    });

    // Swatch click
    swatches.forEach(swatch => {
      swatch.addEventListener('click', () => {
        const color = (swatch as HTMLElement).dataset.color!;
        applyColor(color);
      });
    });

    // Color picker input
    customInput.addEventListener('input', () => {
      applyColor(customInput.value);
    });

    // Hex text input — apply on Enter or blur
    hexInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        tryApplyHex();
        hexInput.blur();
      }
    });
    hexInput.addEventListener('blur', () => {
      tryApplyHex();
    });

    function tryApplyHex() {
      const raw = hexInput.value.replace(/^#/, '').trim();
      if (/^[0-9A-Fa-f]{6}$/.test(raw)) {
        applyColor('#' + raw);
      } else if (/^[0-9A-Fa-f]{3}$/.test(raw)) {
        const expanded = raw.split('').map(c => c + c).join('');
        applyColor('#' + expanded);
      }
    }

    // Reset
    resetBtn.addEventListener('click', () => {
      applyColor(DEFAULT_COLOR);
    });

    function applyColor(color: string) {
      document.documentElement.style.setProperty('--color-forest', color);
      customInput.value = color;
      hexInput.value = color.replace('#', '').toUpperCase();
      localStorage.setItem('demo-forest-color', color);

      // Update active swatch
      swatches.forEach(s => {
        const match = (s as HTMLElement).dataset.color?.toLowerCase() === color.toLowerCase();
        s.classList.toggle('active', match);
      });

      // Update toggle button color
      toggle.style.backgroundColor = color;
    }
  }

  // Run on initial load and on Astro page transitions
  initColorPicker();
  document.addEventListener('astro:after-swap', initColorPicker);
</script>
