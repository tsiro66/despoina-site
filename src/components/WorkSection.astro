---
import { Image } from "astro:assets";

interface Props {
  projects: Array<{
    id: string;
    data: { title: string; image: string; description: string };
  }>;
}
const { projects } = Astro.props;

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/projects/**/*.{jpg,jpeg,png,gif,webp,avif}",
  { eager: true },
);
---

<section class="min-h-screen text-black px-8 md:px-16 lg:px-24 py-20">
  <div class="max-w-7xl mx-auto">
    <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-4">Τα έργα μας</h1>
    <p class="text-lg text-black/80 max-w-2xl font-google-sans mb-16">
      Δείτε τα έργα που έχουμε ολοκληρώσει.
    </p>

    {projects.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {projects.map((project) => {
          const img = images[project.data.image];
          return (
            <a
              href={`/work/${project.id}`}
              aria-label={project.data.title}
              class="work-item group relative overflow-hidden bg-zinc-50 aspect-[4/3] transition-shadow duration-300 focus-visible:ring-2 focus-visible:ring-forest"
            >
              {img && (
                <Image
                  src={img.default}
                  alt=""
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 text-transparent"
                />
              )}
              <div
                class="absolute inset-0 bg-gradient-to-t from-forest/80 via-forest/20 to-transparent opacity-0 group-hover:opacity-100 group-focus-visible:opacity-100 transition-opacity duration-300"
              />
              <div
                class="absolute bottom-0 left-0 right-0 p-8 translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 group-focus-visible:translate-y-0 group-focus-visible:opacity-100 transition-all duration-300"
              >
                <h3 class="text-white text-xl font-bold">{project.data.title}</h3>
              </div>
            </a>
          );
        })}
      </div>
    ) : (
      <p class="text-gray-500 font-google-sans">Δεν υπάρχουν έργα ακόμα.</p>
    )}
  </div>
</section>

<style>
  .work-item {
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 0.6s ease-out,
      transform 0.6s ease-out;
  }
  .work-item.visible {
    opacity: 1;
    transform: translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .work-item {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const items = document.querySelectorAll(".work-item");
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry, i) => {
          if (entry.isIntersecting) {
            setTimeout(() => entry.target.classList.add("visible"), i * 100);
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 },
    );
    items.forEach((item) => observer.observe(item));
  });
</script>
