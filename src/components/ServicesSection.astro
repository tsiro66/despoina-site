---
const services = [
  {
    number: "01",
    title: "Μελέτη",
    description:
      "Lorem ipsum dolor sit amet consectetur adipisicing elit. Inventore doloremque nemo reprehenderit quos harum sapiente culpa autem voluptatem accusamus. Aliquam itaque est eum maxime explicabo.",
    span: "lg:col-span-2",
  },
  {
    number: "02",
    title: "Αδειοδότηση",
    description:
      "Lorem ipsum dolor sit amet consectetur adipisicing elit. Excepturi at tempora nulla delectus accusantium vero pariatur corporis corrupti asperiores. Officiis voluptatum voluptates quaerat suscipit esse.",
    span: "lg:col-span-3",
  },
  {
    number: "03",
    title: "Κατασκευή",
    description:
      "Lorem ipsum dolor sit amet consectetur adipisicing elit. Aliquam itaque est eum maxime explicabo quos harum sapiente culpa autem voluptatem accusamus doloremque facilis tempore voluptatibus illum nobis quaerat praesentium.",
    span: "lg:col-span-5",
  },
];
---

<section class="px-8 md:px-16 lg:px-24 py-16 sm:py-24">

  <!-- Header -->
  <div class="grid grid-cols-1 lg:grid-cols-5 gap-6 mb-12 sm:mb-16">
    <div class="service-card lg:col-span-2 flex flex-col justify-center">
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold text-black leading-tight">Υπηρεσίες</h1>
      <p class="mt-4 text-gray-600 font-google-sans text-base sm:text-lg leading-relaxed">
        Lorem ipsum dolor sit amet consectetur adipisicing elit. Inventore doloremque nemo reprehenderit quos harum sapiente.
      </p>
    </div>
    <div class="service-card lg:col-span-3 border border-forest/40 p-6 sm:p-8 flex items-center corner-extend">
      <p class="text-forest/80 font-google-sans text-base sm:text-lg leading-relaxed">
        Lorem ipsum dolor sit amet consectetur adipisicing elit. Aliquam, itaque est eum maxime explicabo quos harum sapiente culpa autem voluptatem accusamus doloremque.
      </p>
    </div>
  </div>

  <!-- Service cards -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6">
    {services.map((service) => (
      <div class={`service-card bg-zinc-50 border border-forest/40 corner-extend ${service.span}`}>
        <div class="p-5 sm:p-6 lg:p-8">
          <span class="text-sm text-forest/50 font-google-sans tracking-widest">{service.number}</span>
          <h3 class="text-lg sm:text-xl font-bold text-black mt-2">{service.title}</h3>
          <p class="mt-3 text-gray-600 text-sm font-google-sans leading-relaxed">{service.description}</p>
        </div>
      </div>
    ))}
  </div>

</section>

<style>
  .service-card {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }
  .service-card.visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .service-card {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const cards = document.querySelectorAll(".service-card");
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry, i) => {
          if (entry.isIntersecting) {
            setTimeout(() => entry.target.classList.add("visible"), i * 100);
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 }
    );
    cards.forEach((card) => observer.observe(card));
  });
</script>
