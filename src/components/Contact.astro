---
import RollLink from "./RollLink.astro";
---

<section class="px-4 sm:px-8 md:px-16 lg:pl-8 lg:pr-20 py-16 sm:py-24">
  <!-- Header — asymmetric like other pages -->
  <div class="grid grid-cols-1 lg:grid-cols-5 gap-6 mb-12 sm:mb-16">
    <div class="contact-card lg:col-span-2 flex flex-col justify-center">
      <h1
        class="text-3xl sm:text-4xl md:text-5xl font-bold text-black leading-tight"
      >
        Επικοινωνία
      </h1>
      <p
        class="mt-4 text-gray-600 font-google-sans text-base sm:text-lg leading-relaxed"
      >
        Lorem ipsum dolor sit amet consectetur adipisicing elit. Inventore
        doloremque nemo reprehenderit quos harum sapiente.
      </p>
    </div>
    <div
      class="contact-card lg:col-span-3 bg-forest p-6 sm:p-8 shadow-sm flex items-center"
    >
      <p
        class="text-white/80 font-google-sans text-base sm:text-lg leading-relaxed"
      >
        Lorem ipsum dolor sit amet consectetur adipisicing elit. Aliquam, itaque
        est eum maxime explicabo quos harum sapiente culpa autem voluptatem
        accusamus doloremque.
      </p>
    </div>
  </div>

  <!-- Contact grid -->
  <div class="grid grid-cols-1 lg:grid-cols-5 gap-6">
    <!-- Contact form — wider -->
    <div class="contact-card lg:col-span-3 bg-zinc-50 border border-forest/40 corner-extend">
      <div class="p-5 sm:p-6 lg:p-8 h-full">
        <h2 class="text-lg sm:text-xl font-bold text-black mb-6">
          Στείλτε μας μήνυμα
        </h2>

        <form class="flex flex-col gap-5 h-[calc(100%-2.5rem)]">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label
                for="name"
                class="block text-sm font-medium text-black mb-1.5"
                >Ονοματεπώνυμο</label
              >
              <input
                type="text"
                id="name"
                name="name"
                required
                autocomplete="name"
                class="w-full px-4 py-3 bg-zinc-100 border border-transparent text-black text-sm font-google-sans placeholder:text-gray-400 focus:outline-none focus:border-forest/30 transition-colors duration-200"
                placeholder="Το όνομά σας"
              />
            </div>
            <div>
              <label
                for="email"
                class="block text-sm font-medium text-black mb-1.5"
                >Email</label
              >
              <input
                type="email"
                id="email"
                name="email"
                required
                autocomplete="email"
                class="w-full px-4 py-3 bg-zinc-100 border border-transparent text-black text-sm font-google-sans placeholder:text-gray-400 focus:outline-none focus:border-forest/30 transition-colors duration-200"
                placeholder="email@example.com"
              />
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label
                for="phone"
                class="block text-sm font-medium text-black mb-1.5"
                >Τηλέφωνο</label
              >
              <input
                type="tel"
                id="phone"
                name="phone"
                autocomplete="tel"
                class="w-full px-4 py-3 bg-zinc-100 border border-transparent text-black text-sm font-google-sans placeholder:text-gray-400 focus:outline-none focus:border-forest/30 transition-colors duration-200"
                placeholder="+30 210 000 0000"
              />
            </div>
            <div>
              <label
                for="subject"
                class="block text-sm font-medium text-black mb-1.5">Θέμα</label
              >
              <select
                id="subject"
                name="subject"
                class="w-full px-4 py-3 bg-zinc-100 border border-transparent text-black text-sm font-google-sans focus:outline-none focus:border-forest/30 transition-colors duration-200 appearance-none"
              >
                <option value="" disabled selected>Επιλέξτε θέμα</option>
                <option value="new-project">Νέο έργο</option>
                <option value="collaboration">Συνεργασία</option>
                <option value="other">Άλλο</option>
              </select>
            </div>
          </div>

          <div class="flex-1 flex flex-col">
            <label
              for="message"
              class="block text-sm font-medium text-black mb-1.5">Μήνυμα</label
            >
            <textarea
              id="message"
              name="message"
              required
              class="w-full flex-1 px-4 py-3 bg-zinc-100 border border-transparent text-black text-sm font-google-sans placeholder:text-gray-400 focus:outline-none focus:border-forest/30 transition-colors duration-200 resize-none"
              placeholder="Περιγράψτε μας το έργο σας..."></textarea>
          </div>

          <RollLink
            href="#"
            class="corner-extend group/link gap-2 border border-forest/40 text-forest font-medium text-base sm:text-lg px-8 py-3.5 mb-2 max-w-11/20 xl:max-w-3/10"
            text="Αποστολή"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-5 h-5 transition-transform duration-300 group-hover/link:translate-x-2"
              viewBox="0 0 20 20"
              fill="currentColor"
              ><path
                fill-rule="evenodd"
                d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z"
                clip-rule="evenodd"></path></svg
            >
          </RollLink>
        </form>
      </div>
    </div>

    <!-- Info cards — narrower column -->
    <div class="lg:col-span-2 flex flex-col gap-6">
      <!-- Team contact details -->
      <div class="contact-card bg-zinc-50 border border-forest/40 corner-extend">
        <div class="p-5 sm:p-6 lg:p-8">
          <h2 class="text-lg sm:text-xl font-bold text-black mb-5">
            Στοιχεία επικοινωνίας
          </h2>
          <ul class="space-y-4">
            <li class="flex items-center gap-3">
              <div class="w-10 h-10 bg-gray-400 shrink-0"></div>
              <div>
                <span class="text-sm text-black font-bold block"
                  >Όνομα Επώνυμο</span
                >
                <span class="text-sm text-black/60 font-google-sans block"
                  >email@a37.gr</span
                >
                <span class="text-sm text-black/60 font-google-sans block"
                  >+30 210 000 0000</span
                >
              </div>
            </li>
            <li class="flex items-center gap-3">
              <div class="w-10 h-10 bg-blue-500 shrink-0"></div>
              <div>
                <span class="text-sm text-black font-bold block"
                  >Όνομα Επώνυμο</span
                >
                <span class="text-sm text-black/60 font-google-sans block"
                  >email@a37.gr</span
                >
                <span class="text-sm text-black/60 font-google-sans block"
                  >+30 210 000 0000</span
                >
              </div>
            </li>
            <li class="flex items-center gap-3">
              <div class="w-10 h-10 bg-pink-400 shrink-0"></div>
              <div>
                <span class="text-sm text-black font-bold block"
                  >Όνομα Επώνυμο</span
                >
                <span class="text-sm text-black/60 font-google-sans block"
                  >email@a37.gr</span
                >
                <span class="text-sm text-black/60 font-google-sans block"
                  >+30 210 000 0000</span
                >
              </div>
            </li>
            <li class="flex items-center gap-3">
              <div class="w-10 h-10 bg-orange-500 shrink-0"></div>
              <div>
                <span class="text-sm text-black font-bold block"
                  >Όνομα Επώνυμο</span
                >
                <span class="text-sm text-black/60 font-google-sans block"
                  >email@a37.gr</span
                >
                <span class="text-sm text-black/60 font-google-sans block"
                  >+30 210 000 0000</span
                >
              </div>
            </li>
            <li class="flex items-center gap-3">
              <div class="w-10 h-10 bg-green-800 shrink-0"></div>
              <div>
                <span class="text-sm text-black font-bold block"
                  >Όνομα Επώνυμο</span
                >
                <span class="text-sm text-black/60 font-google-sans block"
                  >email@a37.gr</span
                >
                <span class="text-sm text-black/60 font-google-sans block"
                  >+30 210 000 0000</span
                >
              </div>
            </li>
          </ul>
        </div>
      </div>

      <!-- Social links -->
      <div class="contact-card bg-forest shadow-sm">
        <div class="p-5 sm:p-6 lg:p-8">
          <h2 class="text-lg sm:text-xl font-bold text-white mb-5">
            Ακολουθήστε μας
          </h2>
          <div class="flex gap-4">
            <a
              href="#"
              class="w-10 h-10 bg-white/10 flex items-center justify-center hover:bg-white/20 transition-colors duration-200"
              aria-label="Facebook"
            >
              <svg
                class="w-5 h-5 text-white"
                fill="currentColor"
                viewBox="0 0 24 24"
                ><path
                  d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
                ></path></svg
              >
            </a>
            <a
              href="#"
              class="w-10 h-10 bg-white/10 flex items-center justify-center hover:bg-white/20 transition-colors duration-200"
              aria-label="Instagram"
            >
              <svg
                class="w-5 h-5 text-white"
                fill="currentColor"
                viewBox="0 0 24 24"
                ><path
                  d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"
                ></path></svg
              >
            </a>
            <a
              href="#"
              class="w-10 h-10 bg-white/10 flex items-center justify-center hover:bg-white/20 transition-colors duration-200"
              aria-label="LinkedIn"
            >
              <svg
                class="w-5 h-5 text-white"
                fill="currentColor"
                viewBox="0 0 24 24"
                ><path
                  d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                ></path></svg
              >
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-card {
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 0.6s ease-out,
      transform 0.6s ease-out;
  }
  .contact-card.visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .contact-card {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const cards = document.querySelectorAll(".contact-card");
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry, i) => {
          if (entry.isIntersecting) {
            setTimeout(() => entry.target.classList.add("visible"), i * 100);
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 },
    );
    cards.forEach((card) => observer.observe(card));
  });
</script>
