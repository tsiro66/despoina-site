---
import RollLink from "./RollLink.astro";

const navLinks = [
  { name: "Ποιοι είμαστε", href: "/about" },
  { name: "Υπηρεσίες", href: "/services" },
  { name: "Τα έργα μας", href: "/work" },
  { name: "Επικοινωνία", href: "/contact" },
];

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
const isHome = currentPath === "/";
---

<nav
  id="navbar"
  aria-label="Κύρια πλοήγηση"
  class="bg-zinc-50 border-y border-forest/40 sticky top-0 z-200 overflow-visible"
>
  <div class="flex h-16 items-center overflow-visible">
    <!-- Logo cell -->
    <div
      class="shrink-0 flex items-center px-6 lg:w-[var(--nav-logo-w)] lg:px-0 lg:justify-center border-r border-forest/40 self-stretch relative"
    >
      <a href="/" class="flex items-start group no-underline ml-1">
        <span class="text-5xl font-bold text-forest leading-none font-sansation"
          >A</span
        >
        <span class="text-4xl font-bold text-forest/70 -mt-1 -ml-1 leading-none"
          >+</span
        >
      </a>
      <span
        class="absolute -bottom-[2.5px] -right-[3.5px] md:-right-[2.5px] w-[5px] h-[5px] rounded-full bg-forest"
        aria-hidden="true"></span>
    </div>

    <div
      class="hidden lg:flex shrink-0 items-center border-r border-forest/40 self-stretch"
    >
      <div class="flex flex-col justify-center">
        <span
          class="text-xl font-bold text-black tracking-[0.2em] leading-tight uppercase font-geom px-8 text-center"
        >
          Μηχανικοι
        </span>
        <div class="h-[1px] w-full bg-forest/30 my-1"></div>
        <div
          class="flex justify-between items-center text-[10px] text-gray-500 font-medium tracking-widest uppercase px-8"
        >
          <span>Μελέτη</span>
          <span class="text-forest/40 text-[6px] mx-1">●</span>
          <span>Αδειοδότηση</span>
          <span class="text-forest/40 text-[6px] mx-1">●</span>
          <span>Κατασκευή</span>
        </div>
      </div>
    </div>
    <!-- Spacer -->
    <div class="flex-1"></div>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-stretch self-stretch overflow-visible">
      {
        navLinks.map((link) => {
          const isActive = currentPath === link.href;
          return (
            <RollLink
              href={link.href}
              text={link.name}
              class={`text-forest font-medium text-lg border-l border-forest/40 px-6 flex items-center transition-opacity duration-300 ${isActive ? "opacity-100 nav-active" : isHome ? "opacity-100" : "opacity-60 hover:opacity-100"}`}
              aria-current={isActive ? "page" : undefined}
            />
          );
        })
      }
    </div>

    <!-- Mobile hamburger (2 lines → X) -->
    <button
      id="mobile-menu-btn"
      class="md:hidden relative z-[150] flex flex-col justify-center gap-2 w-10 h-10 cursor-pointer mx-4"
      aria-label="Μενού"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span
        id="line1"
        class="block w-full h-[1px] bg-forest transition-all duration-300 origin-center"
      ></span>
      <span
        id="line2"
        class="block w-full h-[1px] bg-forest transition-all duration-300 origin-center"
      ></span>
    </button>
  </div>
</nav>

<!-- Fullscreen mobile menu overlay -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-100 bg-zinc-50 flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300 ease-in-out md:hidden border-b border-forest/40"
>
  <nav aria-label="Μενού κινητού" class="flex flex-col items-center gap-10">
    {
      navLinks.map((link) => {
        const isActive = currentPath === link.href;
        return (
          <RollLink
            href={link.href}
            text={link.name}
            class={`mobile-menu-link text-forest text-3xl font-medium transition-opacity duration-300 ${isHome || isActive ? "opacity-100" : "opacity-60 hover:opacity-100"}`}
            aria-current={isActive ? "page" : undefined}
          />
        );
      })
    }
  </nav>
</div>

<script>
  document.addEventListener("astro:page-load", () => {
    const navbar = document.getElementById("navbar");
    const btn = document.getElementById("mobile-menu-btn");
    const menu = document.getElementById("mobile-menu");
    const line1 = document.getElementById("line1");
    const line2 = document.getElementById("line2");
    let isOpen = false;

    function openMenu() {
      menu?.classList.remove("opacity-0", "pointer-events-none");
      menu?.classList.add("opacity-100", "pointer-events-auto");
      // Lines → X
      line1?.classList.add("translate-y-[4.5px]", "rotate-45");
      line2?.classList.add("-translate-y-[4.5px]", "-rotate-45");
      btn?.setAttribute("aria-expanded", "true");
      document.body.style.overflow = "hidden";
      isOpen = true;
    }

    function closeMenu() {
      menu?.classList.remove("opacity-100", "pointer-events-auto");
      menu?.classList.add("opacity-0", "pointer-events-none");
      // X → lines
      line1?.classList.remove("translate-y-[4.5px]", "rotate-45");
      line2?.classList.remove("-translate-y-[4.5px]", "-rotate-45");
      btn?.setAttribute("aria-expanded", "false");
      document.body.style.overflow = "";
      isOpen = false;
    }

    btn?.addEventListener("click", () => {
      isOpen ? closeMenu() : openMenu();
    });

    // Close on Escape key
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && isOpen) {
        closeMenu();
        btn?.focus();
      }
    });

    // Close on link click
    menu?.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });
  });
</script>
