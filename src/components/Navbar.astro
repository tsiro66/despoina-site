---
import RollLink from "./RollLink.astro";

const navLinks = [
  { name: "Ποιοι είμαστε", href: "/about" },
  { name: "Υπηρεσίες", href: "/services" },
  { name: "Τα έργα μας", href: "/work" },
  { name: "Επικοινωνία", href: "/contact" },
];

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
const isHome = currentPath === "/";
---

<nav
  id="navbar"
  aria-label="Κύρια πλοήγηση"
  class="bg-zinc-50 border-y border-forest/40 sticky top-0 z-200 overflow-visible"
>
  <div class="flex h-16 items-center overflow-visible">
    
    <!-- Unified Clickable Logo & Title Group -->
    <a href="/" class="group flex self-stretch no-underline">
      <!-- Logo cell -->
      <div
        class="shrink-0 flex items-center px-2 md:px-6 lg:w-[var(--nav-logo-w)] lg:px-0 lg:justify-center border-r border-forest/40 self-stretch relative group-hover:bg-zinc-100 transition-colors duration-300"
      >
        <div class="flex items-start ml-2">
          <span class="text-5xl font-bold text-forest leading-none font-sansation">A</span>
          <span class="text-4xl font-bold text-forest/70 -mt-1 -ml-1 leading-none">+</span>
        </div>
        <!-- <span
          class="absolute -bottom-[2.5px] -right-[3.5px] md:-right-[2.5px] w-[5px] h-[5px] rounded-full bg-forest"
          aria-hidden="true"></span> -->
      </div>

      <!-- Text cell -->
      <div
        class="hidden lg:flex shrink-0 items-center border-r border-forest/40 self-stretch group-hover:bg-zinc-100 transition-colors duration-300"
      >
        <div class="flex flex-col justify-center">
          <span
            class="text-xl font-bold text-black tracking-[0.2em] leading-tight uppercase font-geom px-8 text-center"
          >
            Μηχανικοι
          </span>
          <div class="h-[1px] w-full bg-forest/30 my-1"></div>
          <div
            class="flex justify-between items-center text-[10px] text-gray-500 font-medium tracking-widest uppercase px-8"
          >
            <span>Μελέτη</span>
            <span class="text-forest/40 text-[6px] mx-1">●</span>
            <span>Αδειοδότηση</span>
            <span class="text-forest/40 text-[6px] mx-1">●</span>
            <span>Κατασκευή</span>
          </div>
        </div>
      </div>
    </a>

    <!-- Spacer -->
    <div class="flex-1"></div>
    
    <!-- Desktop nav -->
    <div class="hidden md:flex items-stretch self-stretch overflow-visible">
      {
        navLinks.map((link) => {
          const isActive = currentPath === link.href;
          return (
            <RollLink
              href={link.href}
              text={link.name}
              class={`text-forest font-medium text-lg border-l border-forest/40 px-6 flex items-center transition-opacity duration-300 ${isActive ? "opacity-100 nav-active" : isHome ? "opacity-100" : "opacity-60 hover:opacity-100"}`}
              aria-current={isActive ? "page" : undefined}
            />
          );
        })
      }
    </div>

    <!-- Mobile hamburger (2 lines → X) -->
    <button
      id="mobile-menu-btn"
      class="md:hidden relative z-[150] flex flex-col justify-center gap-2 w-10 h-10 cursor-pointer mx-4"
      aria-label="Μενού"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span
        id="line1"
        class="block w-full h-[1px] bg-forest transition-all duration-300 origin-center"
      ></span>
      <span
        id="line2"
        class="block w-full h-[1px] bg-forest transition-all duration-300 origin-center"
      ></span>
    </button>
  </div>
</nav>

<!-- Fullscreen mobile menu overlay -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-100 bg-zinc-50 opacity-0 pointer-events-none transition-opacity duration-300 ease-in-out md:hidden flex flex-col"
>
  <!-- The Grid Container -->
  <nav aria-label="Μενού κινητού" class="flex-1 grid grid-cols-[79px_1fr] grid-rows-[1fr_auto]">
    
    <!-- LEFT COLUMN -->
    <div class="flex flex-col border-r border-forest/40">
      <!-- Top section (empty/spacer to let the vertical line run) -->
      <div class="flex-1 relative">
         <span class="absolute -top-[2.5px] -right-[3.5px] w-[5px] h-[5px] rounded-full bg-forest"></span>
      </div>
      
      <!-- BOTTOM LEFT CELL: Social Icons -->
      <div class="h-50 flex flex-col items-center justify-center gap-10">
        <a href="#" class="text-forest" aria-label="Facebook">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
      </a>
      <a href="#" class="text-forest" aria-label="Instagram">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
      </a>
      <a href="#" class="text-forest" aria-label="LinkedIn">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
      </a>
      </div>
    </div>

    <!-- RIGHT COLUMN -->
    <div class="flex flex-col">
      <!-- Links Area -->
      <div class="flex-1 flex flex-col justify-center">
        {
          navLinks.map((link) => {
            const isActive = currentPath === link.href;
            return (
              <div class="border-b border-forest/15 last:border-forest/40">
                 <RollLink
                  href={link.href}
                  text={link.name}
                  class={`mobile-menu-link block py-6 px-8 text-forest text-3xl font-medium transition-opacity duration-300 ${isHome || isActive ? "opacity-100" : "opacity-60"}`}
                  aria-current={isActive ? "page" : undefined}
                />
              </div>
            );
          })
        }
      </div>

      <!-- BOTTOM RIGHT CELL: Footer Info -->
      <div class="h-32 p-8 flex flex-col justify-center gap-1">
        <p class="text-forest/50 text-[10px] uppercase tracking-[0.2em] font-bold">Επικοινωνία</p>
        <p class="text-forest text-base font-medium">info@example.gr</p>
        <p class="text-forest text-base font-medium">+30 210 000 0000</p>
        <p class="text-forest text-base font-medium">Αθήνα, Ελλάδα</p>
      </div>
    </div>

  </nav>
</div>

<script>
  document.addEventListener("astro:page-load", () => {
    const navbar = document.getElementById("navbar");
    const btn = document.getElementById("mobile-menu-btn");
    const menu = document.getElementById("mobile-menu");
    const line1 = document.getElementById("line1");
    const line2 = document.getElementById("line2");
    let isOpen = false;

    function openMenu() {
      menu?.classList.remove("opacity-0", "pointer-events-none");
      menu?.classList.add("opacity-100", "pointer-events-auto");
      // Lines → X
      line1?.classList.add("translate-y-[4.5px]", "rotate-45");
      line2?.classList.add("-translate-y-[4.5px]", "-rotate-45");
      btn?.setAttribute("aria-expanded", "true");
      document.body.style.overflow = "hidden";
      isOpen = true;
    }

    function closeMenu() {
      menu?.classList.remove("opacity-100", "pointer-events-auto");
      menu?.classList.add("opacity-0", "pointer-events-none");
      // X → lines
      line1?.classList.remove("translate-y-[4.5px]", "rotate-45");
      line2?.classList.remove("-translate-y-[4.5px]", "-rotate-45");
      btn?.setAttribute("aria-expanded", "false");
      document.body.style.overflow = "";
      isOpen = false;
    }

    btn?.addEventListener("click", () => {
      isOpen ? closeMenu() : openMenu();
    });

    // Close on Escape key
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && isOpen) {
        closeMenu();
        btn?.focus();
      }
    });

    // Close on link click
    menu?.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });
  });
</script>
