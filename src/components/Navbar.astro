---
import RollLink from './RollLink.astro';

const navLinks = [
  { name: "Ποιοι είμαστε", href: "/about" },
  { name: "Υπηρεσίες", href: "/services" },
  { name: "Τα έργα μας", href: "/work" },
  { name: "Επικοινωνία", href: "/contact" },
];
---

<nav id="navbar" class="bg-forest sticky top-0 z-200 shadow-lg">
  <div class="max-w-11/12 mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between h-16 items-center">
      <div class="shrink-0 flex items-center">
        <a href="/" class="text-2xl font-bold text-white font-fraunces">
          A37
        </a>
      </div>

      <!-- Desktop nav -->
      <div class="hidden md:flex gap-20 items-center">
        {
          navLinks.map((link) => (
            <RollLink href={link.href} text={link.name} class="text-white font-medium" />
          ))
        }
      </div>

      <!-- Mobile hamburger (2 lines → X) -->
      <button
        id="mobile-menu-btn"
        class="md:hidden relative z-[150] flex flex-col justify-center gap-2 w-10 h-10 cursor-pointer"
        aria-label="Μενού"
        aria-expanded="false"
      >
        <span
          id="line1"
          class="block w-full h-[1px] bg-white transition-all duration-300 origin-center"
        ></span>
        <span
          id="line2"
          class="block w-full h-[1px] bg-white transition-all duration-300 origin-center"
        ></span>
      </button>
    </div>
  </div>
</nav>

<!-- Fullscreen mobile menu overlay -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-100 bg-forest flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300 ease-in-out md:hidden"
>
  <nav class="flex flex-col items-center gap-10">
    {
      navLinks.map((link) => (
        <RollLink href={link.href} text={link.name} class="mobile-menu-link text-white text-3xl font-medium" />
      ))
    }
  </nav>
</div>

<script>
  document.addEventListener("astro:page-load", () => {
    const navbar = document.getElementById("navbar");
    const btn = document.getElementById("mobile-menu-btn");
    const menu = document.getElementById("mobile-menu");
    const line1 = document.getElementById("line1");
    const line2 = document.getElementById("line2");
    let isOpen = false;

    function openMenu() {
      navbar?.classList.remove("shadow-lg");
      menu?.classList.remove("opacity-0", "pointer-events-none");
      menu?.classList.add("opacity-100", "pointer-events-auto");
      // Lines → X
      line1?.classList.add("translate-y-[4.5px]", "rotate-45");
      line2?.classList.add("-translate-y-[4.5px]", "-rotate-45");
      btn?.setAttribute("aria-expanded", "true");
      document.body.style.overflow = "hidden";
      isOpen = true;
    }

    function closeMenu() {
      menu?.classList.remove("opacity-100", "pointer-events-auto");
      menu?.classList.add("opacity-0", "pointer-events-none");
      // X → lines
      line1?.classList.remove("translate-y-[4.5px]", "rotate-45");
      line2?.classList.remove("-translate-y-[4.5px]", "-rotate-45");
      btn?.setAttribute("aria-expanded", "false");
      document.body.style.overflow = "";
      isOpen = false;
    }

    btn?.addEventListener("click", () => {
      isOpen ? closeMenu() : openMenu();
    });

    // Close on link click
    menu?.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });
  });
</script>
