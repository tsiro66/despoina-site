---
import MainLayout from "../layouts/MainLayout.astro";
import RollLink from "../components/RollLink.astro";
import { Image } from "astro:assets";
import bgImg from "../assets/bg-img.jpg";
---

<MainLayout title="Αρχική">

  <div class="p-4 sm:p-8 md:p-16 lg:p-20 lg:min-h-[calc(100vh-64px)] box-border flex flex-col justify-center">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-6 lg:gap-6">

      <!-- Heading + CTA: left column -->
      <div class="hero-fade lg:col-span-2 lg:row-span-2 flex flex-col justify-center">
        <h1 class="text-3xl sm:text-4xl md:text-5xl xl:text-6xl font-bold text-black leading-tight">
          Lorem, ipsum dolor sit amet consectetur adipisicing elit.
        </h1>
        <p class="mt-4 sm:mt-6 text-base sm:text-lg text-gray-600 font-google-sans leading-relaxed">
          Lorem ipsum dolor sit amet consectetur adipisicing elit. Inventore doloremque nemo reprehenderit.
        </p>
        <div class="mt-6 sm:mt-8 flex flex-wrap gap-4">
          <RollLink href="/contact" text="Επικοινωνήστε μαζί μας" class="group/link gap-2 bg-forest text-white font-medium text-base sm:text-lg px-8 py-3.5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 transition-transform duration-300 group-hover/link:translate-x-2" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" /></svg>
          </RollLink>
        </div>
      </div>

      <!-- Image: right side, tall -->
      <div class="hero-fade hero-delay-1 lg:col-span-3 lg:row-span-2 min-h-[280px] sm:min-h-[340px] lg:max-h-[450px] overflow-hidden shadow-md relative group bg-gray-100">
        <Image src={bgImg} alt="A37 project showcase" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 text-transparent" />
        <div class="absolute inset-0 bg-forest/10 mix-blend-multiply pointer-events-none"></div>
      </div>

      <!-- Card 1: wider -->
      <div class="hero-fade hero-delay-2 lg:col-span-3 bg-white shadow-sm">
        <div class="p-5 sm:p-6 lg:p-8">
          <h2 class="text-lg sm:text-xl font-bold text-black mb-2">Ποιοι είμαστε</h2>
          <p class="text-gray-600 text-sm font-google-sans line-clamp-3">
            Lorem ipsum dolor sit amet consectetur adipisicing elit. Aliquam, itaque est eum maxime explicabo quos harum sapiente? Culpa, ex, autem voluptatem, accusamus doloremque facilis tempore voluptatibus illum nobis quaerat praesentium!
          </p>
          <RollLink href="/about" text="Γνωρίστε μας" class="group/link gap-2 text-black font-medium text-sm mt-4 transition-all duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform duration-300 group-hover/link:translate-x-2" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" /></svg>
          </RollLink>
        </div>
      </div>

      <!-- Card 2: narrower -->
      <div class="hero-fade hero-delay-3 lg:col-span-2 bg-white shadow-sm">
        <div class="p-5 sm:p-6 lg:p-8">
          <h2 class="text-lg sm:text-xl font-bold text-black mb-2">Τι προσφέρουμε</h2>
          <p class="text-gray-600 text-sm font-google-sans line-clamp-3">
            Lorem ipsum dolor sit amet consectetur adipisicing elit. Excepturi at tempora nulla delectus, accusantium vero pariatur corporis corrupti asperiores! Officiis voluptatum voluptates quaerat et, suscipit esse. Laborum voluptas culpa ratione?
          </p>
          <RollLink href="/services" text="Δείτε τις υπηρεσίες μας" class="group/link gap-2 text-black font-medium text-sm mt-4 transition-all duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform duration-300 group-hover/link:translate-x-2" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" /></svg>
          </RollLink>
        </div>
      </div>

    </div>
  </div>

  <!-- Work Showcase -->
  <section class="px-4 sm:px-8 md:px-16 lg:px-24 py-16 sm:py-24">

    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between mb-12 sm:mb-16 gap-4">
      <div>
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-black">Τα έργα μας</h2>
        <p class="mt-3 text-gray-600 font-google-sans max-w-md">
          Lorem ipsum dolor sit amet consectetur adipisicing elit. Inventore doloremque.
        </p>
      </div>
      <RollLink href="/work" text="Όλα τα έργα" class="group/link gap-2 text-black font-medium transition-all duration-300 shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 transition-transform duration-300 group-hover/link:translate-x-2" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" /></svg>
      </RollLink>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-6">

      <!-- Project 1 — Featured (tall) -->
      <a href="/work" aria-label="Όνομα Έργου — Κατηγορία" class="work-item group relative overflow-hidden bg-gray-100 md:row-span-2 min-h-[300px] md:min-h-0 shadow-sm hover:shadow-md transition-shadow duration-300 focus-visible:ring-2 focus-visible:ring-forest">
        <Image src={bgImg} alt="" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 text-transparent" />
        <div class="absolute inset-0 bg-gradient-to-t from-forest/80 via-forest/20 to-transparent opacity-0 group-hover:opacity-100 group-focus-visible:opacity-100 transition-opacity duration-300"></div>
        <div class="absolute bottom-0 left-0 right-0 p-6 translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 group-focus-visible:translate-y-0 group-focus-visible:opacity-100 transition-all duration-300">
          <span class="text-white/70 text-sm font-google-sans">Κατηγορία</span>
          <h3 class="text-white text-xl font-bold mt-1">Όνομα Έργου</h3>
        </div>
      </a>

      <!-- Project 2 -->
      <a href="/work" aria-label="Όνομα Έργου — Κατηγορία" class="work-item group relative overflow-hidden bg-gray-100 min-h-[250px] shadow-sm hover:shadow-md transition-shadow duration-300 focus-visible:ring-2 focus-visible:ring-forest">
        <Image src={bgImg} alt="" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 text-transparent" />
        <div class="absolute inset-0 bg-gradient-to-t from-forest/80 via-forest/20 to-transparent opacity-0 group-hover:opacity-100 group-focus-visible:opacity-100 transition-opacity duration-300"></div>
        <div class="absolute bottom-0 left-0 right-0 p-6 translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 group-focus-visible:translate-y-0 group-focus-visible:opacity-100 transition-all duration-300">
          <span class="text-white/70 text-sm font-google-sans">Κατηγορία</span>
          <h3 class="text-white text-xl font-bold mt-1">Όνομα Έργου</h3>
        </div>
      </a>

      <!-- Project 3 -->
      <a href="/work" aria-label="Όνομα Έργου — Κατηγορία" class="work-item group relative overflow-hidden bg-gray-100 min-h-[250px] shadow-sm hover:shadow-md transition-shadow duration-300 focus-visible:ring-2 focus-visible:ring-forest">
        <Image src={bgImg} alt="" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 text-transparent" />
        <div class="absolute inset-0 bg-gradient-to-t from-forest/80 via-forest/20 to-transparent opacity-0 group-hover:opacity-100 group-focus-visible:opacity-100 transition-opacity duration-300"></div>
        <div class="absolute bottom-0 left-0 right-0 p-6 translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 group-focus-visible:translate-y-0 group-focus-visible:opacity-100 transition-all duration-300">
          <span class="text-white/70 text-sm font-google-sans">Κατηγορία</span>
          <h3 class="text-white text-xl font-bold mt-1">Όνομα Έργου</h3>
        </div>
      </a>

      <!-- Project 4 -->
      <a href="/work" aria-label="Όνομα Έργου — Κατηγορία" class="work-item group relative overflow-hidden bg-gray-100 min-h-[250px] lg:col-span-2 shadow-sm hover:shadow-md transition-shadow duration-300 focus-visible:ring-2 focus-visible:ring-forest">
        <Image src={bgImg} alt="" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 text-transparent" />
        <div class="absolute inset-0 bg-gradient-to-t from-forest/80 via-forest/20 to-transparent opacity-0 group-hover:opacity-100 group-focus-visible:opacity-100 transition-opacity duration-300"></div>
        <div class="absolute bottom-0 left-0 right-0 p-6 translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 group-focus-visible:translate-y-0 group-focus-visible:opacity-100 transition-all duration-300">
          <span class="text-white/70 text-sm font-google-sans">Κατηγορία</span>
          <h3 class="text-white text-xl font-bold mt-1">Όνομα Έργου</h3>
        </div>
      </a>

    </div>

  </section>

  <style>
    /* Staggered fade-up entrance */
    .hero-fade {
      opacity: 0;
      transform: translateY(24px);
      animation: heroFadeUp 0.7s ease-out forwards;
    }
    .hero-delay-1 { animation-delay: 0.15s; }
    .hero-delay-2 { animation-delay: 0.3s; }
    .hero-delay-3 { animation-delay: 0.45s; }

    @keyframes heroFadeUp {
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* Respect reduced-motion: show content immediately, no animation */
    @media (prefers-reduced-motion: reduce) {
      .hero-fade {
        opacity: 1;
        transform: none;
        animation: none;
      }
      .work-item {
        opacity: 1;
        transform: none;
        transition: none;
      }
    }

    /* Scroll-triggered fade for work items */
    .work-item {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.6s ease-out, transform 0.6s ease-out;
    }
    .work-item.visible {
      opacity: 1;
      transform: translateY(0);
    }
  </style>

  <script>
    document.addEventListener("astro:page-load", () => {
      const items = document.querySelectorAll(".work-item");
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry, i) => {
            if (entry.isIntersecting) {
              setTimeout(() => entry.target.classList.add("visible"), i * 100);
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15 }
      );
      items.forEach((item) => observer.observe(item));
    });
  </script>

</MainLayout>
