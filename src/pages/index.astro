---
import MainLayout from "../layouts/MainLayout.astro";
import { Image } from "astro:assets";
import bgImg from "../assets/bg-img.jpg";
---

<MainLayout title="A37 — Αρχική">

  <div class="p-4 sm:p-8 md:p-16 lg:p-24 lg:h-[calc(100vh-64px)] box-border">
    <div class="grid grid-cols-1 lg:grid-cols-2 h-full gap-8 lg:gap-20">

      <!-- Top Left: Big Heading -->
      <div class="flex items-center justify-center px-4 pt-8 sm:px-8 sm:py-12 lg:px-12 lg:py-16">
        <h1 class="text-3xl sm:text-4xl md:text-5xl xl:text-6xl font-bold text-forest leading-tight">
          Lorem, ipsum dolor sit amet consectetur adipisicing elit.
        </h1>
      </div>

      <!-- Top Right: Image -->
      <div class="min-h-[250px] sm:min-h-[300px] lg:min-h-0 overflow-hidden">
        <Image src={bgImg} alt="" class="w-full h-full object-cover" />
      </div>

      <!-- Bottom Left: Card -->
      <div class="flex flex-col bg-white">
        <div class="p-6 sm:p-8 lg:p-10 pb-4 sm:pb-6">
          <h2 class="text-xl sm:text-2xl font-bold text-forest mb-4">Ποιοι είμαστε</h2>
          <p class="text-gray-600 text-sm sm:text-base font-google-sans">
            Lorem ipsum dolor sit amet consectetur adipisicing elit. Aliquam, itaque est eum maxime explicabo quos harum sapiente? Culpa, ex, autem voluptatem, accusamus doloremque facilis tempore voluptatibus illum nobis quaerat praesentium!
          </p>
        </div>
        <a href="/about" class="flex items-center justify-center bg-forest text-white text-center font-medium text-base sm:text-lg py-4 hover:bg-forest/90 transition-colors">
          Γνωρίστε μας
        </a>
      </div>

      <!-- Bottom Right: Card -->
      <div class="flex flex-col bg-white">
        <div class="p-6 sm:p-8 lg:p-10 pb-4 sm:pb-6">
          <h2 class="text-xl sm:text-2xl font-bold text-forest mb-4">Τα έργα μας</h2>
          <p class="text-gray-600 text-sm sm:text-base font-google-sans">
            Lorem ipsum dolor sit amet consectetur adipisicing elit. Excepturi at tempora nulla delectus, accusantium vero pariatur corporis corrupti asperiores! Officiis voluptatum voluptates quaerat et, suscipit esse. Laborum voluptas culpa ratione?
          </p>
        </div>
        <a href="/work" class="flex items-center justify-center bg-forest text-white text-center font-medium text-base sm:text-lg py-4 hover:bg-forest/90 transition-colors">
          Δείτε τα έργα μας
        </a>
      </div>

    </div>
  </div>

</MainLayout>
