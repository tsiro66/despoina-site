---
import { ClientRouter } from 'astro:transitions';
import Navbar from '../components/Navbar.astro';
import '../styles/global.css';
import { Font } from 'astro:assets';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Professional Site",
  description = "A high-performance website built with Astro"
} = Astro.props;
---

<!doctype html>
<html lang="el">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <Font cssVariable="--font-syne" />
    <Font cssVariable="--font-geom" />
    <Font cssVariable="--font-google-sans" />
    <Font cssVariable="--font-fraunces" />
    <Font cssVariable="--font-inter" />
    <ClientRouter />
    <title>{`A37 | ${title}`}</title>

  </head>
  <body class="bg-zinc-100 font-geom">
    
    <Navbar />

    <main class="min-h-[calc(100vh-64px)]">
      <slot /> </main>

  </body>
</html>
